{
  "version": "2.1.0",
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/master/Schemata/sarif-schema-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "Claude Security Analysis",
          "version": "1.0.0",
          "informationUri": "https://www.anthropic.com",
          "rules": [
            {
              "id": "CWE-190",
              "name": "IntegerOverflow",
              "shortDescription": {
                "text": "Integer Overflow or Wraparound"
              },
              "fullDescription": {
                "text": "Arithmetic operations can produce values that exceed the storage capacity of the integer type, leading to unexpected behavior."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/190.html",
              "properties": {
                "tags": [
                  "correctness",
                  "security"
                ],
                "precision": "high",
                "problem.severity": "warning"
              }
            },
            {
              "id": "CWE-22",
              "name": "PathTraversal",
              "shortDescription": {
                "text": "Improper Limitation of a Pathname to a Restricted Directory"
              },
              "fullDescription": {
                "text": "The software uses external input to construct a pathname that is intended to identify a file or directory that is located underneath a restricted parent directory, but does not properly neutralize special elements within the pathname."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/22.html",
              "properties": {
                "tags": [
                  "security"
                ],
                "precision": "high",
                "problem.severity": "error"
              }
            },
            {
              "id": "CWE-89",
              "name": "SQLInjection",
              "shortDescription": {
                "text": "Improper Neutralization of Special Elements used in an SQL Command"
              },
              "fullDescription": {
                "text": "User-controlled input is incorporated into SQL queries without proper sanitization or parameterization, allowing an attacker to manipulate the query logic."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/89.html",
              "properties": {
                "tags": [
                  "security",
                  "correctness"
                ],
                "precision": "very-high",
                "problem.severity": "error"
              }
            },
            {
              "id": "CWE-338",
              "name": "WeakPRNG",
              "shortDescription": {
                "text": "Use of Cryptographically Weak Pseudo-Random Number Generator"
              },
              "fullDescription": {
                "text": "The product uses a Pseudo-Random Number Generator (PRNG) in a security context, but the PRNG is not cryptographically strong."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/338.html",
              "properties": {
                "tags": [
                  "security",
                  "cryptography"
                ],
                "precision": "high",
                "problem.severity": "error"
              }
            },
            {
              "id": "CWE-327",
              "name": "BrokenCryptoAlgorithm",
              "shortDescription": {
                "text": "Use of a Broken or Risky Cryptographic Algorithm"
              },
              "fullDescription": {
                "text": "The use of a broken or risky cryptographic algorithm is an unnecessary risk that may result in the exposure of sensitive information."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/327.html",
              "properties": {
                "tags": [
                  "security",
                  "cryptography"
                ],
                "precision": "very-high",
                "problem.severity": "error"
              }
            },
            {
              "id": "CWE-798",
              "name": "HardcodedCredentials",
              "shortDescription": {
                "text": "Use of Hard-coded Credentials"
              },
              "fullDescription": {
                "text": "The software contains hard-coded credentials, such as a password or cryptographic key, which it uses for authentication or for forming connections to resources."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/798.html",
              "properties": {
                "tags": [
                  "security",
                  "maintainability"
                ],
                "precision": "very-high",
                "problem.severity": "error"
              }
            },
            {
              "id": "CWE-532",
              "name": "SensitiveDataInLogs",
              "shortDescription": {
                "text": "Information Exposure Through Log Files"
              },
              "fullDescription": {
                "text": "Information written to log files can be of a sensitive nature and give valuable guidance to an attacker or expose sensitive user information."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/532.html",
              "properties": {
                "tags": [
                  "security",
                  "privacy"
                ],
                "precision": "high",
                "problem.severity": "warning"
              }
            },
            {
              "id": "CWE-434",
              "name": "UnrestrictedFileUpload",
              "shortDescription": {
                "text": "Unrestricted Upload of File with Dangerous Type"
              },
              "fullDescription": {
                "text": "The software allows the upload of files with dangerous types that can be automatically processed within the product's environment."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/434.html",
              "properties": {
                "tags": [
                  "security"
                ],
                "precision": "high",
                "problem.severity": "error"
              }
            },
            {
              "id": "CWE-611",
              "name": "XXEInjection",
              "shortDescription": {
                "text": "Improper Restriction of XML External Entity Reference"
              },
              "fullDescription": {
                "text": "The software processes an XML document that can contain XML entities with URIs that resolve to documents outside of the intended sphere of control."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/611.html",
              "properties": {
                "tags": [
                  "security"
                ],
                "precision": "high",
                "problem.severity": "error"
              }
            },
            {
              "id": "CWE-78",
              "name": "CommandInjection",
              "shortDescription": {
                "text": "Improper Neutralization of Special Elements used in an OS Command"
              },
              "fullDescription": {
                "text": "User-controlled input is passed to an OS command execution function without proper neutralization, allowing arbitrary command execution."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/78.html",
              "properties": {
                "tags": [
                  "security",
                  "correctness"
                ],
                "precision": "high",
                "problem.severity": "error"
              }
            },
            {
              "id": "CWE-79",
              "name": "XSS",
              "shortDescription": {
                "text": "Improper Neutralization of Input During Web Page Generation (Cross-site Scripting)"
              },
              "fullDescription": {
                "text": "The software does not neutralize or incorrectly neutralizes user-controllable input before it is placed in output that is used as a web page that is served to other users."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/79.html",
              "properties": {
                "tags": [
                  "security",
                  "correctness"
                ],
                "precision": "high",
                "problem.severity": "error"
              }
            },
            {
              "id": "CWE-1004",
              "name": "PromptInjection",
              "shortDescription": {
                "text": "Sensitive Information Embedded in LLM System Prompt"
              },
              "fullDescription": {
                "text": "Sensitive data embedded in LLM system prompts can be extracted via prompt injection attacks. Secrets should never be placed in system prompts."
              },
              "helpUri": "https://owasp.org/www-project-top-10-for-large-language-model-applications/",
              "properties": {
                "tags": [
                  "security",
                  "ai"
                ],
                "precision": "high",
                "problem.severity": "error"
              }
            },
            {
              "id": "CWE-787",
              "name": "OutOfBoundsWrite",
              "shortDescription": {
                "text": "Out-of-bounds Write"
              },
              "fullDescription": {
                "text": "The software writes data past the end, or before the beginning, of the intended buffer, leading to memory corruption and potentially arbitrary code execution or privilege escalation."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/787.html",
              "properties": {
                "tags": [
                  "security",
                  "correctness"
                ],
                "precision": "high",
                "problem.severity": "error"
              }
            },
            {
              "id": "CWE-656",
              "name": "SecurityThroughObscurity",
              "shortDescription": {
                "text": "Reliance on Security Through Obscurity"
              },
              "fullDescription": {
                "text": "The software uses a protection mechanism whose strength depends heavily on its obscurity, such that knowledge of its algorithms or key data is sufficient to defeat the mechanism."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/656.html",
              "properties": {
                "tags": [
                  "security"
                ],
                "precision": "high",
                "problem.severity": "warning"
              }
            },
            {
              "id": "CWE-829",
              "name": "InclusionFromUntrustedControlSphere",
              "shortDescription": {
                "text": "Inclusion of Functionality from Untrusted Control Sphere"
              },
              "fullDescription": {
                "text": "The software imports, requires, or includes executable functionality from a source that is outside of the intended control sphere."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/829.html",
              "properties": {
                "tags": [
                  "security",
                  "supply-chain"
                ],
                "precision": "high",
                "problem.severity": "error"
              }
            },
            {
              "id": "CWE-20",
              "name": "ImproperInputValidation",
              "shortDescription": {
                "text": "Improper Input Validation"
              },
              "fullDescription": {
                "text": "The product receives input or data, but it does not validate or incorrectly validates that the input has the properties that are required to process the data safely and correctly."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/20.html",
              "properties": {
                "tags": [
                  "security",
                  "correctness"
                ],
                "precision": "high",
                "problem.severity": "error"
              }
            },
            {
              "id": "CWE-915",
              "name": "ImproperlyControlledObjectModification",
              "shortDescription": {
                "text": "Improperly Controlled Modification of Dynamically-Determined Object Attributes"
              },
              "fullDescription": {
                "text": "The software receives input from an upstream component that specifies multiple attributes, properties, or fields that are to be initialized or updated in an object, but it does not properly control which attributes can be modified."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/915.html",
              "properties": {
                "tags": [
                  "security"
                ],
                "precision": "high",
                "problem.severity": "error"
              }
            },
            {
              "id": "CWE-1321",
              "name": "PrototypePollution",
              "shortDescription": {
                "text": "Improperly Controlled Modification of Object Prototype Attributes"
              },
              "fullDescription": {
                "text": "The software receives input from an upstream component that specifies attributes that are to be initialized or updated in an object, but it does not properly control modifications of attributes of the Object prototype, allowing attackers to inject properties into existing JavaScript objects."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/1321.html",
              "properties": {
                "tags": [
                  "security"
                ],
                "precision": "high",
                "problem.severity": "error"
              }
            },
            {
              "id": "CWE-362",
              "name": "RaceCondition",
              "shortDescription": {
                "text": "Concurrent Execution Using Shared Resource with Improper Synchronization"
              },
              "fullDescription": {
                "text": "The program contains a code sequence that can run concurrently with other code, and the code sequence requires temporary, exclusive access to a shared resource, but a timing window exists in which the shared resource can be modified by another code sequence that is operating concurrently."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/362.html",
              "properties": {
                "tags": [
                  "security",
                  "correctness"
                ],
                "precision": "high",
                "problem.severity": "error"
              }
            },
            {
              "id": "CWE-204",
              "name": "ObservableResponseDiscrepancy",
              "shortDescription": {
                "text": "Observable Response Discrepancy"
              },
              "fullDescription": {
                "text": "The product provides different responses to incoming requests in a way that reveals internal state information to an unauthorized actor, such as whether a valid username exists."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/204.html",
              "properties": {
                "tags": [
                  "security",
                  "privacy"
                ],
                "precision": "high",
                "problem.severity": "warning"
              }
            },
            {
              "id": "CWE-209",
              "name": "ErrorMessageInformationExposure",
              "shortDescription": {
                "text": "Generation of Error Message Containing Sensitive Information"
              },
              "fullDescription": {
                "text": "The software generates an error message that includes sensitive information about its environment, users, or associated data."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/209.html",
              "properties": {
                "tags": [
                  "security",
                  "privacy"
                ],
                "precision": "high",
                "problem.severity": "warning"
              }
            },
            {
              "id": "CWE-400",
              "name": "UncontrolledResourceConsumption",
              "shortDescription": {
                "text": "Uncontrolled Resource Consumption"
              },
              "fullDescription": {
                "text": "The software does not properly control the allocation and maintenance of a limited resource, thereby enabling an actor to influence the amount of resources consumed, eventually leading to the exhaustion of available resources."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/400.html",
              "properties": {
                "tags": [
                  "security",
                  "availability"
                ],
                "precision": "high",
                "problem.severity": "warning"
              }
            },
            {
              "id": "CWE-476",
              "name": "NullPointerDereference",
              "shortDescription": {
                "text": "NULL Pointer Dereference"
              },
              "fullDescription": {
                "text": "A NULL pointer dereference occurs when the application dereferences a pointer that it expects to be valid but is NULL, typically causing a crash or exit."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/476.html",
              "properties": {
                "tags": [
                  "correctness",
                  "security"
                ],
                "precision": "high",
                "problem.severity": "warning"
              }
            },
            {
              "id": "CWE-208",
              "name": "ObservableTimingDiscrepancy",
              "shortDescription": {
                "text": "Observable Timing Discrepancy"
              },
              "fullDescription": {
                "text": "Two separate operations in a product require different amounts of time to complete in a way that is observable to an actor and may reveal security-relevant information about the state of the product."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/208.html",
              "properties": {
                "tags": [
                  "security"
                ],
                "precision": "medium",
                "problem.severity": "note"
              }
            },
            {
              "id": "CWE-1333",
              "name": "InefficientRegularExpression",
              "shortDescription": {
                "text": "Improper Control of a Regular Expression"
              },
              "fullDescription": {
                "text": "The product uses a regular expression with an inefficient, possibly exponential worst-case computational complexity that consumes excessive CPU cycles."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/1333.html",
              "properties": {
                "tags": [
                  "security",
                  "availability"
                ],
                "precision": "medium",
                "problem.severity": "note"
              }
            }
          ]
        }
      },
